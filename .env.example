# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

BOLNA_API_KEY=bn-xxxx
BOLNA_AGENT_ID=your-agent-id

CARTESIA_API_KEY=sk_car_xxxx
# Saathi's warm Hindi voice id (from the Bolna Audio tab) — also speaks the Kannada card
CARTESIA_HINDI_VOICE_ID=
# Optional dedicated/localized Kannada voice. If unset, the Hindi voice id is used at language=kn.
CARTESIA_KANNADA_VOICE_ID=
# Back-compat fallback if the two above are unset
CARTESIA_VOICE_ID=

# Public base URL (ngrok) so dashboard clips / SMS links resolve
PUBLIC_BASE_URL=http://localhost:8000

# Optional: best-effort Hindi→Kannada symptom translation fallback
ANTHROPIC_API_KEY=

# Optional overrides
# CARTESIA_VERSION=2025-04-16
# CARTESIA_MODEL=sonic-3
